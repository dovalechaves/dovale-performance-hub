# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE de variáveis de ambiente. NÃO coloque segredos reais aqui — este
# arquivo é versionado no Git. Preencha os valores reais no .env (ignorado pelo
# Git) ou no painel de variáveis do Coolify, por ambiente.
# Substitua todos os "__PREENCHER__" pelos valores corretos.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Ambiente / jobs ─────────────────────────────────────────────────────────
# ENABLE_JOBS=true faz os crons (snapshot de estoque, multi-preço, cobrança)
# subirem junto com o servidor. Deixe AUSENTE/!= "true" em homologação para
# evitar disparos duplicados contra produção.
ENABLE_JOBS=true

